{
  "name": "PharmaBot",
  "image": "mcr.microsoft.com/devcontainers/universal:2",

  // Runs every time the codespace starts or resumes from sleep
  "postStartCommand": "export PATH=/home/codespace/.python/current/bin:$HOME/.local/bin:$PATH && bash /workspaces/PharmaBot/.devcontainer/start.sh",

  // Auto-forward ports and set them public
  "portsAttributes": {
    "5173": {
      "label": "PharmaBot Frontend",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "8000": {
      "label": "PharmaBot Backend",
      "onAutoForward": "silent",
      "visibility": "private"
    }
  },

  "forwardPorts": [5173, 8000]
}
